user  nginx;
worker_processes  auto;

error_log  /var/log/nginx/error.log notice;
pid        /var/run/nginx.pid;

events {
    worker_connections  1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # Hiding version info
    server_tokens off;

    # Log format optimized for API latency tracking
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for" '
                      'rt=$request_time uct="$upstream_connect_time" uht="$upstream_header_time" urt="$upstream_response_time"';

    access_log  /var/log/nginx/access.log  main;

    sendfile        on;
    keepalive_timeout  65;

    # ----------------------------------------------------------------------
    # UPSTREAM DEFINITION (The 8-GPU Split)
    # ----------------------------------------------------------------------
    # Nginx acts as a Load Balancer for the vLLM workers.
    # We use "least_conn" strategy: send the request to the GPU that is 
    # currently handling the fewest requests.
    upstream vllm_backend {
        least_conn;
${UPSTREAM_SERVERS}
    }

    server {
        # Internal Listening Port (matches compose/base.yml)
        listen 5000;
        
        # ------------------------------------------------------------------
        # SECURITY: Internal ACLs
        # ------------------------------------------------------------------
        # Only allow traffic from the Docker Internal Network.
        # This protects against accidental port mapping on the host.
        allow 10.0.0.0/8;      # Standard Docker Class A
        allow 172.16.0.0/12;   # Standard Docker Class B (Bridge)
        deny all;              # Drop everything else

        location / {
            # Proxy Configuration
            proxy_pass http://vllm_backend;
            include /etc/nginx/proxy_params.conf;

            # --------------------------------------------------------------
            # LLM SPECIFIC TIMEOUTS
            # --------------------------------------------------------------
            # Large Language Models take time to generate tokens.
            # Connect: If vLLM is dead, fail fast (60s).
            proxy_connect_timeout   60s;
            # Read/Send: Allow up to 1 Hour for massive prompts, 
            # "Reasoning" pauses, or long batch generations.
            proxy_read_timeout      3600s;
            proxy_send_timeout      3600s;
        }

        # Healthcheck endpoint for Docker
        location /health {
            access_log off;
            return 200 "healthy\n";
        }
    }
}
