# ==============================================================================
# MAIN HTTPS INGRESS
server {
    listen 443 ssl;
    server_name ${SERVER_NAME};

    # Certificates (Found at these paths via Secure Entrypoint shim)
    # fullchain.pem should contain: [Server Cert] + [Intermediate Certs]
    ssl_certificate     /etc/nginx/certs/fullchain.pem;
    ssl_certificate_key /run/secrets/certificate_key;

    client_max_body_size 100M;
    
    # --- TLS HARDENING ---
    # 1. Protocols: Disable legacy TLS 1.0/1.1 (vulnerable to POODLE/BEAST attacks).
    ssl_protocols TLSv1.2 TLSv1.3;

    # 2. Preference: Server chooses the cipher, not the client (prevents downgrade attacks).
    ssl_prefer_server_ciphers on;

    # 3. Ciphers: ALLOWED ALGORITHMS LIST (Public Config - NOT A SECRET)
    #    This whitelist permits only high-security encryption methods (Perfect Forward Secrecy).
    #    It blocks weak, obsolete algorithms that might be enabled by default.
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    
    # --- SECURITY HEADERS ---
    # 1. Prevent MIME Sniffing
    add_header X-Content-Type-Options "nosniff" always;

    # 2. XSS Protection (Legacy Defense)
    add_header X-XSS-Protection "1; mode=block" always;

    # 3. Content Security Policy (Strict Whitelisting)
    # Breakdown:
    # - default-src 'self': Only load things from this domain.
    # - connect-src ... ws: wss:: Allow WebSockets (Critical for streaming chat).
    # - style-src ... 'unsafe-inline': OpenWebUI uses inline CSS styles.
    # - script-src ... 'unsafe-eval': Required for some Python/JS dynamic execution in UI frameworks.
    add_header Content-Security-Policy "default-src 'self'; connect-src 'self' ws: wss:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; frame-ancestors 'none';" always;

    # 4. Strict Transport Security (HSTS)
    # Tells browser to NEVER try HTTP again for this domain, only HTTPS.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    
    # --- SECURITY: ACL ---
    # We use a variable injected by Nginx envsubst
    # Default behavior if var is missing is handled in compose or start script
    ${NGINX_ACL_ALLOW_LIST}
    deny all;

    # --- SECURITY: Rate Limiting ---
    limit_req zone=perip_limit burst=1000 nodelay;

    # ==========================================================================
    # DYNAMIC MODULE: GRAFANA
    # ==========================================================================
    # This block is injected by 'generate_ingress_config.sh' ONLY if
    # ENABLE_INTERNAL_METRICS=true. Otherwise, it remains empty.
    ${GRAFANA_LOCATION_BLOCK}

    # ==========================================================================
    # APPLICATION ROUTING
    # ==========================================================================

    # 1. WebSockets
    location /ws/ {
        proxy_pass http://frontend:8080/ws/;
        proxy_http_version 1.1;
        
        # Connection Upgrade logic
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        
        # Standard Forwarding
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Origin protection (Often needed for WS)
        proxy_set_header Origin "";
        
        # Long timeouts for chat sessions
        proxy_read_timeout 60m;
        proxy_send_timeout 60m;
    }

    # 2. Optional Dictation App
    ${DICTATION_LOCATION_BLOCK}

    # 3. Optional ICD-10 Coding API
    ${ICD10_LOCATION_BLOCK}

    # 4. API
    location /api/ {
        proxy_pass http://frontend:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60m;
    }

    # 5. Web UI (Catch-all)
    location / {
        proxy_pass http://frontend:8080/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60m;
    }
}

# ==============================================================================
# HTTP Redirect
server {
    listen 80;
    server_name ${SERVER_NAME};
    location / {
        return 301 https://$host$request_uri;
    }
}

# ------------------------------------------------------------------------------
# DEFAULT DENY (Unknown Hostnames)
# ------------------------------------------------------------------------------
server {
    listen 443 ssl default_server;
    server_name _;
    ssl_certificate     /etc/nginx/certs/fullchain.pem;
    ssl_certificate_key /run/secrets/certificate_key;
    return 444;
}

server {
    listen 80 default_server;
    server_name _;
    return 444;
}
